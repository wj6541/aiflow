{
  "name": "aiflow-workspace",
  "version": "0.1.1",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "aiflow-workspace",
      "version": "0.1.1",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/aiflow-kit": {
      "resolved": "packages/cli",
      "link": true
    },
    "packages/cli": {
      "name": "aiflow-kit",
      "version": "0.1.1",
      "license": "MIT",
      "bin": {
        "aiflow": "src/cli.js"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
